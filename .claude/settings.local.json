{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash",
      "mcp__playwright",
      "WebFetch(domain:smithery.ai)",
      "WebFetch(domain:github.com)",
      "Skill(git:commit)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["playwright"],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/format-on-save.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/log-bash.sh"
          }
        ]
      }
    ]
  }
}
